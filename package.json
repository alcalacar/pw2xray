{
  "name": "pw2xray",
  "version": "0.2.0",
  "description": "Cliente ligero de la API de Xray Cloud (Jira) para reportar resultados de Playwright: sube ejecuciones JUnit/Cucumber, adjunta evidencia por test y por step, sincroniza escenarios Cucumber (import+verificar+tag) y escanea secretos en pre-commit.",
  "type": "commonjs",
  "license": "MIT",
  "author": "Carlos Alcalá <alcalacarcis@gmail.com>",
  "homepage": "https://github.com/alcalacar/pw2xray#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alcalacar/pw2xray.git"
  },
  "bugs": {
    "url": "https://github.com/alcalacar/pw2xray/issues"
  },
  "keywords": ["playwright", "xray", "jira", "cucumber", "testing", "qa", "ci"],
  "main": "src/xray.ts",
  "files": ["src"],
  "exports": {
    "./xray": "./src/xray.ts",
    "./playwright-report": "./src/playwright-report.ts",
    "./check-secrets": "./src/check-secrets.ts",
    "./upload-to-xray": "./src/upload-to-xray.ts",
    "./step-evidence-reporter": "./src/step-evidence-reporter.ts",
    "./sync-scenario": "./src/sync-scenario.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "typescript": "^7.0.2"
  }
}
